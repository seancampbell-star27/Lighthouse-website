---
/**
 * Circular rotating text — "Transparency → Technology → People →" — recreated
 * from the original site's spinning SVG (theirs rotated via CSS spin).
 */
interface Props {
  /** CSS size, e.g. "220px" */
  size?: string;
}
const { size = '220px' } = Astro.props;
---

<div class="spin-wrap" style={`width:${size};height:${size};`} role="img" aria-label="Our values: transparency, technology, people">
  <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <path
        id="value-circle"
        d="M 100,100 m -74,0 a 74,74 0 1,1 148,0 a 74,74 0 1,1 -148,0"
      />
    </defs>
    <!-- gold arc accent -->
    <circle
      cx="100"
      cy="100"
      r="88"
      fill="none"
      stroke="#F4D35E"
      stroke-width="3"
      stroke-dasharray="138 415"
      stroke-linecap="round"
      transform="rotate(115 100 100)"
    />
    <g class="spin-text">
      <text fill="#074F89" font-size="15.5" font-weight="600" letter-spacing="1.5">
        <textPath href="#value-circle" startOffset="0">Transparency</textPath>
        <textPath href="#value-circle" startOffset="30.5%">→</textPath>
        <textPath href="#value-circle" startOffset="36%">Technology</textPath>
        <textPath href="#value-circle" startOffset="63.5%">→</textPath>
        <textPath href="#value-circle" startOffset="69%">People</textPath>
        <textPath href="#value-circle" startOffset="90%">→</textPath>
      </text>
    </g>
  </svg>
</div>

<style>
  .spin-wrap {
    position: relative;
  }
  .spin-wrap svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .spin-text {
    transform-origin: 100px 100px;
    animation: values-spin 16s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .spin-text {
      animation: none;
    }
  }
  @keyframes values-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
