---
/**
 * Lighthouse logo mark, rebuilt as vectors from the brand logo, with the
 * animated light beam from the original site: a gold beam sweeps around the
 * light source while the navy mark stays static on top.
 * Geometry traced from input/lighthouse_digital_media.jpg (mark region).
 */
interface Props {
  /** CSS size, e.g. "40px" */
  size?: string;
}
const { size = '40px' } = Astro.props;
---

<svg
  class="animated-mark"
  viewBox="0 0 132 132"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  style={`width:${size};height:${size};`}
>
  <!-- Sweeping beam (behind the mark) -->
  <g class="mark-beam">
    <polygon points="43,89 132,62 132,84" fill="#F4D35E" opacity="0.55" />
  </g>
  <!-- Light source -->
  <rect class="mark-light" x="37" y="83" width="12" height="12" fill="#F4D35E" />
  <!-- Static navy mark -->
  <g fill="#074F89">
    <rect x="1" y="1" width="34" height="81" />
    <rect x="1" y="97" width="34" height="34" />
    <polygon points="51,82 77,1 131,1 131,50" />
    <rect x="50" y="97" width="81" height="34" />
  </g>
</svg>

<style>
  .animated-mark {
    display: block;
    flex-shrink: 0;
  }
  .mark-beam {
    transform-origin: 43px 89px;
    animation: mark-sweep 7s linear infinite;
  }
  .mark-light {
    animation: mark-glow 3.5s ease-in-out infinite;
  }
  @keyframes mark-sweep {
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes mark-glow {
    0%,
    100% {
      opacity: 0.65;
    }
    50% {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .mark-beam,
    .mark-light {
      animation: none;
    }
  }
</style>
