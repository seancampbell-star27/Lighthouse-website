---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: data.author },
};
---

<BaseLayout title={data.title} description={data.description} jsonLd={articleLd}>
  <article class="section">
    <div class="container article">
      <a href="/blog" class="back-link">← All posts</a>
      <header class="article-head">
        <time datetime={data.pubDate.toISOString()}>{fmt(data.pubDate)}</time>
        <h1>{data.title}</h1>
        <p class="byline">By {data.author}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
  }
  .back-link {
    font-weight: 600;
    font-size: 0.92rem;
  }
  .article-head {
    margin: 1.25rem 0 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }
  .article-head time {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .article-head h1 {
    margin: 0.5rem 0 0.5rem;
  }
  .byline {
    margin: 0;
    color: var(--muted);
  }
  .prose :global(h2) {
    margin-top: 2rem;
    font-size: 1.5rem;
  }
  .prose :global(h3) {
    margin-top: 1.5rem;
  }
  .prose :global(p) {
    line-height: 1.75;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.25rem;
    line-height: 1.75;
  }
  .prose :global(a) {
    text-decoration: underline;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--gold);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--ink);
    font-family: var(--ff-serif);
    font-size: 1.15rem;
  }
</style>
