---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContentPending from '../components/ContentPending.astro';

// Replace with real team members: name, title, short bio, headshot in
// /public/images/team/. Keep count flexible.
const slots = [1, 2, 3, 4];
---

<BaseLayout
  title="The Team"
  description="Meet the people behind Lighthouse Digital Media — experienced digital planners, buyers, and analysts who run your campaigns hands-on."
>
  <PageHero
    eyebrow="The team"
    title="The people behind your campaigns"
    subtitle="We believe the success of a campaign hinges on the expertise and integrity of the people driving it. Here&rsquo;s who you&rsquo;ll work with."
  />

  <section class="section">
    <div class="container">
      <ContentPending note="No team bios, titles, or headshots were captured. Add real names, roles, short bios, and photos (to /public/images/team/) before launch." />
      <div class="grid-team">
        {slots.map(() => (
          <div class="card member reveal">
            <div class="avatar" aria-hidden="true"></div>
            <h3>Name</h3>
            <p class="role">Title</p>
            <p class="bio">Short bio pending.</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .grid-team {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .member {
    text-align: center;
  }
  .avatar {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    margin: 0 auto 1rem;
    background: linear-gradient(135deg, var(--surface-2), var(--gold-soft));
    border: 1px solid var(--line);
  }
  .member h3 {
    color: var(--navy);
    margin-bottom: 0.15rem;
  }
  .role {
    color: var(--muted);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.6rem;
  }
  .bio {
    font-size: 0.92rem;
    color: var(--muted);
    font-style: italic;
  }
</style>
