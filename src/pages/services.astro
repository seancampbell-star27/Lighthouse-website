---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const services = [
  {
    id: 'search',
    title: 'Search',
    intro:
      'Manage and expand brand visibility across Google and Microsoft (Bing). Reach existing and potential customers with optimized messaging and strategic keyword bidding to drive consideration, intent, and conversion. Employ Shopping and Performance Max opportunities to elevate your search presence and eComm goals.',
    points: [
      'Audit of past campaigns and historical performance',
      'Strategic plan designed around your site experience, primary KPI, and overall marketing goals',
      'Account structure, including ad copy, asset management, and keyword research',
      'Management of vertical-specific policy needs, account verifications, and platform specifics',
    ],
  },
  {
    id: 'social',
    title: 'Social Media',
    intro:
      'Amplify your existing presence on social media with strategically targeted ads of all formats. Target existing followers and design lookalike audiences based on their social-specific behaviors.',
    points: [
      'Identify the best platform(s) and audience targeting to achieve your post-click goals',
      'Align messaging with existing social presence for a cohesive ad experience',
      'Incorporate sound and movement and maximize all available ad formats',
      'Stay up to date with policy updates, platform changes, and new opportunities',
      'Ensure brand safety using extensive knowledge of platform specifics',
    ],
  },
  {
    id: 'video',
    title: 'Video',
    intro:
      'Video is rapidly becoming an essential component of digital strategy, reaching across channels, devices, and mediums. Engage your audience with compelling movement and messaging, driving to your website via a click or a QR code.',
    points: [
      'Cost-effective video opportunities in pre-roll, traditional TV, CTV or OTT for your audience and geo',
      'High-impact options to elevate your messaging, improve recall, and drive site traffic from TV',
      'Attribution and retargeting options to maximize the impact of TV across other channels',
      'Detailed performance on content types, providers, and audience engagement',
    ],
  },
  {
    id: 'programmatic',
    title: 'Programmatic',
    intro:
      'Access Display, Audio, Video, and Out-of-Home inventory via best-in-class demand platforms. Make multiple channels work together to drive prospects down funnel, build retargeting pools, and create demand.',
    points: [
      'Extensive programmatic buying experience within Basis DSP, Google, and leading demand-side platforms',
      'Inventory and tactic selection tailored to your available assets, audience, and goals',
      'Hyperfocus on brand safety and inventory quality — block-listing, exchange and domain-level optimization, and publisher selection',
    ],
  },
  {
    id: 'ad-operations',
    title: 'Ad Operations',
    intro:
      'Effective optimization of your campaigns and in-depth analysis of your data, to help you make informed decisions for your brand.',
    points: [
      'Establishing a learning agenda during the planning phase, to align on test-and-learn opportunities',
      'Focusing optimization strategy around a primary KPI, while incorporating secondary and macro-level goals',
      'Providing consistent and relevant insights into your campaign performance and audience engagement',
    ],
  },
];
---

<BaseLayout
  title="Strategy & Buying"
  description="Lighthouse plans, executes, and optimizes digital campaigns across search, social, video, programmatic, and ad operations — built around your goals and benchmarks."
>
  <PageHero
    eyebrow="Strategy & buying"
    title="We plan, execute, and optimize digital campaigns"
    subtitle="Using your marketing goals, challenges, and past performance, our team designs an approach that maximizes your budget and assets, reaches your audience, and out-performs your benchmarks — optimizing toward the agreed KPI and reporting on key learnings throughout."
  />

  <nav class="service-tabs" aria-label="Service sections">
    <div class="container">
      <ul>
        {services.map((s) => <li><a href={`#${s.id}`}>{s.title}</a></li>)}
      </ul>
    </div>
  </nav>

  {services.map((s, i) => (
    <section id={s.id} class={`section service-block ${i % 2 ? 'section--tint' : ''}`}>
      <div class="container service-grid reveal">
        <div class="service-intro">
          <h2>{s.title}</h2>
          <p>{s.intro}</p>
        </div>
        <ul class="service-list">
          {s.points.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    </section>
  ))}

  <section class="section section--navy">
    <div class="container">
      <figure class="quote reveal">
        <div class="stars" aria-label="Five out of five stars">★★★★★</div>
        <blockquote>
          With retail changing so drastically during Covid, we decided to
          outsource our digital media buying in hopes of finding trusted experts
          in the retail space. Fortunately for us, we found Lighthouse Digital
          Media and have been working with them ever since. The team is smart,
          caring, and collaborative, and they&rsquo;ve helped us grow our business
          for three straight years.
        </blockquote>
        <figcaption>
          <strong>Nick Sackett</strong>
          <span>President, Acme</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-inner reveal">
      <h2>Ready to plan your next campaign?</h2>
      <p class="lede">Let&rsquo;s map your goals to the right mix of channels.</p>
      <a href="/contact" class="btn btn--primary">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .service-tabs {
    position: sticky;
    top: 72px;
    z-index: 50;
    background: var(--white);
    border-bottom: 1px solid var(--line);
  }
  .service-tabs ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0.9rem 0;
  }
  .service-tabs a {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--navy);
  }
  .service-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .service-intro h2 {
    color: var(--navy);
  }
  .service-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.85rem;
  }
  .service-list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--body);
  }
  .service-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 3px;
    background: var(--gold);
    box-shadow: inset 0 0 0 2px var(--navy);
  }

  .quote {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  .stars {
    color: var(--gold);
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }
  .quote blockquote {
    font-family: var(--ff-serif);
    font-size: clamp(1.2rem, 1.1rem + 0.8vw, 1.55rem);
    line-height: 1.5;
    color: var(--white);
    margin: 0 0 1.5rem;
  }
  .quote figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .quote figcaption strong {
    color: var(--white);
  }
  .quote figcaption span {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
  }

  .cta-band {
    background: linear-gradient(120deg, var(--navy) 0%, var(--navy-dark) 100%);
    color: var(--white);
  }
  .cta-inner {
    text-align: center;
    max-width: 640px;
  }
  .cta-inner h2 {
    color: var(--white);
  }
  .cta-inner .lede {
    color: rgba(255, 255, 255, 0.85);
    margin-inline: auto;
    margin-bottom: 1.75rem;
  }

  @media (max-width: 800px) {
    .service-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .service-tabs {
      top: 64px;
    }
  }
</style>
