---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContentPending from '../components/ContentPending.astro';

const features = [
  {
    title: 'Built around your KPIs',
    body:
      'Dashboards are customized to each campaign and learning objective, so the metrics that matter to your business are front and center.',
  },
  {
    title: 'Accurate and timely',
    body:
      'Near real-time data you can trust, refreshed automatically so reporting conversations start from the same numbers.',
  },
  {
    title: 'Transparent by default',
    body:
      'Working media, fees, and pacing are clearly separated — no black boxes between your spend and your results.',
  },
  {
    title: 'Cross-channel in one view',
    body:
      'Search, social, video, and programmatic performance unified, so you can compare channels and reallocate with confidence.',
  },
];
---

<BaseLayout
  title="Custom Dashboards"
  description="Comprehensive, custom performance dashboards built around your campaigns and learning objectives — accurate, timely, and transparent."
>
  <PageHero
    eyebrow="Data & analytics"
    title="Custom dashboards built around your goals"
    subtitle="Data accessibility and transparency are crucial to strong client-agency communication and maximizing performance. Every Lighthouse client receives comprehensive dashboards tailored to their specific campaigns and learning objectives."
  />

  <section class="section">
    <div class="container">
      <div class="grid-features">
        {features.map((f) => (
          <div class="card reveal">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== LIVE SAMPLE DASHBOARD ============== -->
  <section class="section section--tint">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">See it live</span>
        <h2>Explore a sample dashboard</h2>
        <p class="lede">
          A working multi-channel performance dashboard — the same structure our
          clients use to track spend, pacing, and results across every channel.
          Use the filters and page controls just like a client would.
        </p>
      </div>

      <div class="dash-embed reveal">
        <div class="dash-embed-placeholder" id="dash-placeholder">
          <img
            src="/images/dashboard-web/paid-media-summary.webp"
            alt="Sample paid media summary dashboard showing spend, impressions, clicks, CPC, CTR and CPM scorecards, a click performance trend chart, and a channel performance table"
            width="1072"
            height="801"
            loading="lazy"
            decoding="async"
          />
          <div class="dash-embed-overlay">
            <p class="dash-embed-title">Sample Multi-Channel Performance Dashboard</p>
            <p class="dash-embed-sub">11 pages · Search, social, video &amp; programmatic · Interactive filters</p>
            <button type="button" class="btn btn--primary" id="dash-load">Load interactive dashboard</button>
          </div>
        </div>
      </div>
      <div class="dash-gallery reveal">
        <figure>
          <img
            src="/images/dashboard-web/paid-search-summary.webp"
            alt="Paid search summary dashboard page with campaign performance broken out by brand and non-brand"
            width="1067" height="801" loading="lazy" decoding="async"
          />
          <figcaption>Channel deep-dives — every channel gets its own summary page</figcaption>
        </figure>
        <figure>
          <img
            src="/images/dashboard-web/click-performance.webp"
            alt="Click performance over time chart with partner and creative performance table"
            width="997" height="547" loading="lazy" decoding="async"
          />
          <figcaption>Trends and creative-level detail, filterable by partner and concept</figcaption>
        </figure>
      </div>

      <p class="dash-embed-fallback">
        Prefer a full-screen view?
        <a
          href="https://lookerstudio.google.com/reporting/88143c73-d46a-462b-b637-57a75a68d706/page/p_b2rsx7f90c"
          target="_blank"
          rel="noopener"
        >Open the sample dashboard in a new tab ↗</a>
      </p>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-inner reveal">
      <h2>Want to see a sample dashboard?</h2>
      <p class="lede">We&rsquo;ll walk you through how we&rsquo;d report on your campaigns.</p>
      <a href="/contact" class="btn btn--primary">Request a walkthrough</a>
    </div>
  </section>
</BaseLayout>

<script>
  // Click-to-load keeps Google's embed JS out of the critical path (CWV).
  // The report's display mode must be "Fit to width" in Looker Studio
  // (View menu) — Looker then scales the report to the iframe itself.
  // On small screens the embed is unusable, so open the report directly.
  const EMBED_URL =
    'https://lookerstudio.google.com/embed/reporting/88143c73-d46a-462b-b637-57a75a68d706/page/p_b2rsx7f90c';
  const FULL_URL =
    'https://lookerstudio.google.com/reporting/88143c73-d46a-462b-b637-57a75a68d706/page/p_b2rsx7f90c';

  const btn = document.getElementById('dash-load');
  btn?.addEventListener('click', () => {
    if (window.innerWidth < 700) {
      window.open(FULL_URL, '_blank', 'noopener');
      return;
    }
    const holder = document.querySelector('.dash-embed');
    if (!holder) return;
    const iframe = document.createElement('iframe');
    iframe.src = EMBED_URL;
    iframe.title = 'Sample multi-channel performance dashboard (Looker Studio)';
    iframe.setAttribute('allowfullscreen', '');
    iframe.setAttribute(
      'sandbox',
      'allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox'
    );
    // Inline styles: Astro's scoped CSS can't target JS-created elements.
    iframe.style.cssText = 'width:100%;height:100%;border:0;display:block;';
    holder.replaceChildren(iframe);
    holder.classList.add('is-live');
  });
</script>

<style>
  .dash-embed {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--white);
    aspect-ratio: 4 / 3;
    max-height: 820px;
  }
  .dash-embed.is-live {
    aspect-ratio: auto;
    max-height: none;
    height: min(78vh, 900px);
  }
  .dash-embed-placeholder {
    position: relative;
    height: 100%;
  }
  .dash-embed-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
  .dash-embed-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    padding: 2rem;
    background: rgba(245, 248, 251, 0.82);
    backdrop-filter: blur(2px);
  }
  .dash-embed-title {
    font-family: var(--ff-serif);
    font-size: 1.35rem;
    color: var(--ink);
    margin: 0;
  }
  .dash-embed-sub {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0 0 1rem;
  }
  .dash-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }
  .dash-gallery figure {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--white);
    box-shadow: var(--shadow);
  }
  .dash-gallery figcaption {
    padding: 0.85rem 1.1rem;
    font-size: 0.9rem;
    color: var(--muted);
    border-top: 1px solid var(--line);
  }
  @media (max-width: 720px) {
    .dash-gallery {
      grid-template-columns: 1fr;
    }
  }
  .dash-embed-fallback {
    margin-top: 0.9rem;
    font-size: 0.92rem;
    color: var(--muted);
  }
  .section-head {
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  .grid-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .grid-features h3 {
    color: var(--navy);
  }
  .cta-band {
    background: linear-gradient(120deg, var(--navy) 0%, var(--navy-dark) 100%);
    color: var(--white);
  }
  .cta-inner {
    text-align: center;
    max-width: 640px;
  }
  .cta-inner h2 {
    color: var(--white);
  }
  .cta-inner .lede {
    color: rgba(255, 255, 255, 0.85);
    margin-inline: auto;
    margin-bottom: 1.75rem;
  }
</style>
